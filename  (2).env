# ── Grid Identity ─────────────────────────────────────────────────
GRID_INSIGNIA=MSTR-⚡
GRID_ARCHITECT=The Flame Architect
GRID_VERSION=2.1-soulprinted

# ── Ollama ────────────────────────────────────────────────────────
# Host: WSL2 localhost (not 10.255.255.254 — that was the old bridge IP)
OLLAMA_HOST=http://localhost:11434
OLLAMA_URL=http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# Models path: where Ollama stores downloaded model blobs on WSL2
# Default is ~/.ollama/models — set explicitly so nothing drifts
OLLAMA_MODELS=/home/idona/.ollama/models

# Sovereign model (unified public-facing name)
OLLAMA_MODEL=mostar/mostar-ai:latest

# DCX Trinity — mapped to actual pulled base models
OLLAMA_MODEL_DCX0=phi4
OLLAMA_MODEL_DCX1=qwen2.5
OLLAMA_MODEL_DCX2=mistral

# ── Neo4j ─────────────────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=mostar123

# ── Supabase (AFRO Sentinel) ─────────────────────────────────────
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── WHO / DHIS2 ──────────────────────────────────────────────────
WHO_API_KEY=
WHO_API_BASE=
DHIS2_BASE_URL=
DHIS2_USERNAME=
DHIS2_PASSWORD=

# ── Logistics ────────────────────────────────────────────────────
AFROTRACK_API_KEY=
PDX_API_KEY=
PDX_API_BASE=

# ── Communication ────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TWILIO_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE=

# ── PM2 ──────────────────────────────────────────────────────────
