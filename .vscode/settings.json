{
    // Spell checker
    "cSpell.words": [
        "akiniobong",
        "Mostar",
        "OLLAMA",
        "uvicorn",
        "fastapi",
        "neo4j",
        "gtts",
        "moscript"
    ],
    // Neo4j connection
    "neo4j.connection": {
        "url": "neo4j+s://1d55c1d3.databases.neo4j.io"
    },
    // Python configuration
    "python.defaultInterpreterPath": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
    "python.terminal.activateEnvironment": true,
    "python.analysis.typeCheckingMode": "basic",
    "python.linting.enabled": true,
    "python.linting.pylintEnabled": false,
    "python.linting.flake8Enabled": true,
    "python.formatting.provider": "black",
    // Java configuration
    "java.jdt.ls.java.home": "C:\\Tools\\jdk-17.0.17+10",
    "java.configuration.runtimes": [
        {
            "name": "JavaSE-17",
            "path": "C:\\Tools\\jdk-17.0.17+10",
            "default": true
        },
        {
            "name": "JavaSE-25",
            "path": "C:\\Tools\\jdk-25.0.1+8"
        }
    ],
    // Git configuration
    "git.path": "C:\\Tools\\git-2.52.0.windows.1\\bin\\git.exe",
    // Terminal environment
    "terminal.integrated.env.windows": {
        "JAVA_HOME": "C:\\Tools\\jdk-17.0.17+10",
        "PYTHON_HOME": "C:\\Tools\\python-3.15.0a3-embed-amd64",
        "NODE_HOME": "C:\\Tools\\node-v24.12.0-win-x64",
        "Path": "${env:Path};C:\\Tools\\onnxruntime-1.23.2\\lib;C:\\Tools\\PortableGit\\bin;C:\\Tools\\python-3.15.0a3-embed-amd64;C:\\Tools\\docker;C:\\Tools\\dotnet-sdk-10.0.101-win-x64;C:\\Tools\\git-2.52.0.windows.1\\bin;C:\\Tools\\jdk-17.0.17+10\\bin;C:\\Tools\\jdk-25.0.1+8\\bin;C:\\Tools\\miniforge-25.11.0-1\\Scripts;C:\\Tools\\miniforge-25.11.0-1\\Library\\bin;C:\\Tools\\node-v24.12.0-win-x64"
    },
    // Editor settings
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
        "source.organizeImports": "explicit"
    },
    "editor.rulers": [
        88,
        120
    ],
    // File associations
    "files.associations": {
        "*.cypher": "cypher",
        "*.ps1": "powershell",
        "Dockerfile*": "dockerfile"
    },
    // Exclude patterns
    "files.exclude": {
        "**/__pycache__": true,
        "**/*.pyc": true,
        "**/.pytest_cache": true,
        "**/node_modules": true,
        "**/.next": true
    },
    // Search exclude
    "search.exclude": {
        "**/node_modules": true,
        "**/.venv": true,
        "**/backend/neo4j-mostar-industries/data": true,
        "**/backend/neo4j-mostar-industries/logs": true,
        "**/frontend/.next": true,
        "**/frontend/node_modules": true
    }
}