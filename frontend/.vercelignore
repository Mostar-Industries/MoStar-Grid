# Non-frontend folders to ignore completely
backend/
data/
jdk*/
.tools/
.venv/
node_modules/

# Ignore large data dumps inside those folders specifically if needed
# but better to ignore the whole folders above.

# Ignore build artifacts
.next/
frontend/.next/
frontend/node_modules/

# Large non-code files
*.mp3
*.zip
*.csv
*neo4j-mostar-industries/data/**

# Keep essential configuration
!package.json
!package-lock.json
!vercel.json
!.vercelignore
!frontend/package.json

# Tooling scripts
*.bat
*.ps1
*.sh

# Environment
.env.local
.env.*.local
